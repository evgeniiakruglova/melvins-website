        "subject": "=Hey {{ $json.name.split(' ')[0] }}, following up from Goal Training Academy ⚽",
        "message": "=<div style=\"font-family:Arial,sans-serif;max-width:600px;margin:0 auto;padding:20px;background:#ffffff;\">\n  <div style=\"text-align:center;padding:20px 0;border-bottom:3px solid #c4a24e;\">\n    <h1 style=\"color:#1a1a2e;margin:0;font-size:24px;\">GOAL Training Academy</h1>\n    <p style=\"color:#c4a24e;margin:5px 0 0;font-size:14px;\">Elevate Your Game</p>\n  </div>\n  <div style=\"padding:20px 0;\">\n    <p style=\"color:#333;font-size:16px;\">Hey {{ $json.name.split(' ')[0] }},</p>\n    <p style=\"color:#333;font-size:16px;\">It's Coach Melvin from Goal Training Academy. Got your message about {{ $json.program }} training for your {{ $json.player_age }} year old. Just wanted to follow up and make sure we connect.</p>\n    <p style=\"color:#333;font-size:16px;\">I know finding the right training environment matters. I'd love to chat about what we can do for your kid.</p>\n    <p style=\"color:#333;font-size:16px;\">I'll give you a call soon. Feel free to text or reply back if that's easier.</p>\n    <p style=\"color:#333;font-size:16px;\">Talk soon,<br>Coach Melvin</p>\n  </div>\n  <div style=\"border-top:1px solid #eee;padding:15px 0;text-align:center;\">\n    <p style=\"color:#999;font-size:12px;margin:0;\">Goal Training Academy | Lakeland, FL</p>\n    <p style=\"color:#999;font-size:12px;margin:5px 0 0;\">Youth Soccer Training for Ages 7-18</p>\n  </div>\n</div>",
