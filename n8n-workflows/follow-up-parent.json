    {
      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "// Quiet hours: no emails between 9 PM and 8 AM Eastern\nconst nowUTC = new Date();\nconst easternOffset = -4; // EDT (Eastern Daylight Time - March is DST)\nconst easternHour = (nowUTC.getUTCHours() + easternOffset + 24) % 24;\nif (easternHour >= 22 || easternHour < 7) {\n  return []; // Quiet hours - stop execution\n}\n\n// Filter: melvin_contacted=FALSE, follow_up_sent=FALSE, older than 12 hours\nconst twelveHoursAgo = new Date(nowUTC.getTime() - 12 * 60 * 60 * 1000);\nconst leads = $input.all();\nconst needsFollowUp = leads.filter(item => {\n  const d = item.json;\n  const ts = new Date(d.timestamp);\n  return (\n    String(d.melvin_contacted).toUpperCase() === 'FALSE' &&\n    String(d.follow_up_sent).toUpperCase() === 'FALSE' &&\n    ts < twelveHoursAgo\n  );\n});\n\nif (needsFollowUp.length === 0) {\n  return [];\n}\n\nreturn needsFollowUp;"
      },
      "type": "n8n-nodes-base.code",
